{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npx prisma generate && npx next build",
  "devCommand": "next dev",
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 30
    }
  }
}
