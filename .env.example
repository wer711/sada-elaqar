# ─── Database (Turso — serverless SQLite, required for Vercel) ───
# Turso is a free serverless SQLite database that works with Vercel's
# read-only filesystem. Get your credentials at https://turso.tech
#
# Setup (3 minutes):
#   1. Sign up at https://turso.tech/app/signup (use GitHub for speed)
#   2. Create a database (name it "sada-aqar")
#   3. Copy the URL (libsql://your-db.turso.io)
#   4. Click "Show Token" and copy the auth token
#   5. Paste both below
#
# For local development without Turso, you can use a file: URL instead:
#   DATABASE_URL=file:./db/custom.db
#   (leave DATABASE_AUTH_TOKEN empty)
DATABASE_URL=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token-here

# ─── WhatsApp numbers ───
# PUBLIC: the number shown to visitors in the WhatsApp widget + footer.
# Use a Saudi/Gulf number for brand consistency in the MENA market.
# Format: country code + number, no "+" or spaces. Example: 9665XXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=966500000000

# BACKUP: the real operational number (used internally by the team).
# Not shown in the UI. Kept for backend/operational use only.
BACKUP_WHATSAPP_NUMBER=213696212465

# ─── Google Sheets CRM webhook (RECOMMENDED) ───
# This is your CRM. Every lead + feedback is pushed here in real time.
#
# Setup (5 minutes):
#   1. Create a new Google Sheet, name it "صدى العقار - CRM"
#   2. Extensions → Apps Script → paste the contents of download/google-apps-script.gs
#   3. Run setupAllSheets() once (creates the 4 sheets with headers)
#   4. Deploy → New deployment → Web app
#      - Execute as: Me
#      - Who has access: Anyone
#   5. Copy the Web App URL (https://script.google.com/macros/s/XXXX/exec)
#   6. Paste it below (uncomment)
#
# The 4 sheets created automatically:
#   - Leads_Free       : free registrants + their demo behavior
#   - Leads_Founder    : paying founder members (Phase 4)
#   - Feedback_Free    : feedback from free users (Phase 5)
#   - Feedback_Founder : feedback from founders (Phase 5, with priority)
#
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# ─── PayPal (founder plan payments) ───
# PayPal is how we collect the $29 founder payments (card / PayPal balance).
# Works in Algeria + most countries — create a PayPal Business account.
#
# Setup (10 minutes):
#   1. Go to https://developer.paypal.com → Log into Dashboard
#   2. My Apps & Credentials → Create App (or use the Default App)
#   3. Copy the Client ID + Secret
#   4. Set the mode: Sandbox for testing, Live for production
#   5. Paste the values below (uncomment)
#
# Sandbox (testing):
#   - Use https://api-m.sandbox.paypal.com as PAYPAL_API_BASE
#   - Test with sandbox accounts from developer.paypal.com
# Live (production):
#   - Use https://api-m.paypal.com as PAYPAL_API_BASE
#
# Flow:
#   Visitor clicks "اشترك" → PayPal Smart Buttons appear
#   → user pays in PayPal popup → onApprove → /api/payment/paypal/capture
#   → we capture the payment, activate Subscription, assign founderNumber,
#     push to Leads_Founder sheet
#
# Public client ID (exposed to the browser — safe to expose, it's public)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Private secret (server-side only — NEVER expose to the browser)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# API base URL — sandbox for testing, live for production
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# ─── Debug (OPTIONAL) ───
# Set to 1 to see every SQL query in the server console (useful for development).
# Leave unset in production to keep logs clean and avoid leaking PII.
# DEBUG_SQL=1
